@model OnlineShop.Areas.Admin.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "داشبورد";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="col-12">

    <!-- Header -->

    <div class="row mb-2">

        <div class="col-12">

            <div class="card border-0 shadow-sm rounded-4">

                <div class="card-body d-flex justify-content-between align-items-center flex-wrap">

                    <div>

                        <h2 class="fw-bold text-success mb-1">

                            <i class="bi bi-speedometer2 ms-2"></i>

                            داشبورد مدیریت

                        </h2>

                        <p class="text-muted mb-0">

                            خوش آمدید

                            <strong>@User.Identity?.Name</strong>

                        </p>

                    </div>

                    <div class="text-end">

                        <span class="badge bg-warning text-dark fs-6 px-4 py-3 rounded-pill">

                            <i class="bi bi-calendar3 ms-2"></i>

                            @DateTime.Now.ToString("yyyy/MM/dd")

                        </span>

                    </div>

                </div>

            </div>

        </div>

    </div>



    <!-- Cards -->

    <div class="row g-4 mb-2">

        <div class="col-xl-3 col-lg-6 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body d-flex align-items-center">

                    <div class="bg-success bg-opacity-10 rounded-circle p-3 ms-3">

                        <i class="bi bi-box-seam text-success fs-2"></i>

                    </div>

                    <div>

                        <small class="text-muted">

                            محصولات

                        </small>

                        <h2 class="fw-bold mt-1">

                            @Model.ProductsCount

                        </h2>

                    </div>

                </div>

            </div>

        </div>



        <div class="col-xl-3 col-lg-6 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body d-flex align-items-center">

                    <div class="bg-warning bg-opacity-10 rounded-circle p-3 ms-3">

                        <i class="bi bi-grid text-warning fs-2"></i>

                    </div>

                    <div>

                        <small class="text-muted">

                            دسته بندی

                        </small>

                        <h2 class="fw-bold mt-1">

                            @Model.CategoriesCount

                        </h2>

                    </div>

                </div>

            </div>

        </div>



        <div class="col-xl-3 col-lg-6 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body d-flex align-items-center">

                    <div class="bg-primary bg-opacity-10 rounded-circle p-3 ms-3">

                        <i class="bi bi-people text-primary fs-2"></i>

                    </div>

                    <div>

                        <small class="text-muted">

                            کاربران

                        </small>

                        <h2 class="fw-bold mt-1">

                            @Model.UsersCount

                        </h2>

                    </div>

                </div>

            </div>

        </div>



        <div class="col-xl-3 col-lg-6 col-md-6">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-body d-flex align-items-center">

                    <div class="bg-danger bg-opacity-10 rounded-circle p-3 ms-3">

                        <i class="bi bi-cart3 text-danger fs-2"></i>

                    </div>

                    <div>

                        <small class="text-muted">

                            سفارش ها

                        </small>

                        <h2 class="fw-bold mt-1">

                            @Model.OrdersCount

                        </h2>

                    </div>

                </div>

            </div>

        </div>

    </div>
    <!-- سفارش‌ها و کاربران -->

    <div class="row g-4">

        <!-- آخرین سفارش‌ها -->

        <div class="col-lg-8">

            <div class="card border-0 shadow-sm rounded-4 h-100">

                <div class="card-header bg-white border-0 py-3">

                    <h5 class="mb-0 fw-bold text-success">

                        <i class="bi bi-cart-check ms-2"></i>

                        آخرین سفارش‌ها

                    </h5>

                </div>

                <div class="table-responsive">

                    <table class="table align-middle table-hover mb-0">

                        <thead class="table-light">

                            <tr>

                                <th>شماره</th>

                                <th>کاربر</th>

                                <th>مبلغ</th>

                                <th>وضعیت</th>

                            </tr>

                        </thead>

                        <tbody>

                            @if (Model.LatestOrders.Any())
                            {
                                @foreach (var item in Model.LatestOrders.Take(3))
                                {
                                    <tr>

                                        <td>#@item.Id</td>

                                        <td>@(item.FullName ?? "-")</td>

                                        <td>@item.TotalPrice.ToString("N0") تومان</td>

                                        <td>

                                            @if (item.PaymentStatus == "Paid")
                                            {
                                                <span class="badge bg-success">
                                                    پرداخت شده
                                                </span>
                                            }
                                            else if (item.PaymentStatus == "Pending")
                                            {
                                                <span class="badge bg-warning text-dark">
                                                    در انتظار
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">
                                                    ناموفق
                                                </span>
                                            }

                                        </td>

                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>

                                    <td colspan="4" class="text-center py-4 text-muted">

                                        سفارشی ثبت نشده است.

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>



        <!-- آخرین کاربران -->

        <div class="col-lg-4">

            <div class="card border-0 shadow-sm rounded-4 h-75">

                <div class="card-header bg-white border-0 py-3">

                    <h5 class="mb-0 fw-bold text-success">

                        <i class="bi bi-people ms-2"></i>

                        آخرین کاربران

                    </h5>

                </div>

                <div class="list-group list-group-flush">

                    @if (Model.LatestUsers.Any())
                    {
                        @foreach (var user in Model.LatestUsers.Take(2))
                        {
                            <div class="list-group-item border-0 d-flex align-items-center py-3">

                                <div class="rounded-circle bg-success text-white d-flex justify-content-center align-items-center ms-3"
                                     style="width:48px;height:48px;">

                                    @(string.IsNullOrWhiteSpace(user.UserName)
                                        ? "?"
                                        : user.UserName.Substring(0, 1).ToUpper())

                                </div>

                                <div>

                                    <div class="fw-bold">

                                        @user.UserName

                                    </div>

                                    <small class="text-muted">

                                        @user.Email

                                    </small>

                                </div>

                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">

                            <i class="bi bi-person-x fs-1"></i>

                            <div class="mt-2">

                                کاربری یافت نشد

                            </div>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>
    <!-- دسترسی سریع -->

    <div class="row mt-2">

        <div class="col-12">

            <div class="card border-0 shadow-sm rounded-4">

                <div class="card-header bg-white border-0 py-3">

                    <h5 class="fw-bold text-success mb-0">

                        <i class="bi bi-lightning-charge ms-2"></i>

                        دسترسی سریع

                    </h5>

                </div>

                <div class="card-body">

                    <div class="row g-3">

                        <div class="col-xl-2 col-lg-4 col-md-6">

                            <a asp-action="Products"
                               class="btn btn-outline-success w-100 py-3 rounded-3">

                                <i class="bi bi-box-seam fs-4 d-block mb-2"></i>

                                محصولات

                            </a>

                        </div>

                        <div class="col-xl-2 col-lg-4 col-md-6">

                            <a asp-action="Categories"
                               class="btn btn-outline-warning w-100 py-3 rounded-3">

                                <i class="bi bi-grid fs-4 d-block mb-2"></i>

                                دسته‌بندی

                            </a>

                        </div>

                        <div class="col-xl-2 col-lg-4 col-md-6">

                            <a asp-action="Orders"
                               class="btn btn-outline-primary w-100 py-3 rounded-3">

                                <i class="bi bi-cart3 fs-4 d-block mb-2"></i>

                                سفارش‌ها

                            </a>

                        </div>

                        <div class="col-xl-2 col-lg-4 col-md-6">

                            <a asp-action="Users"
                               class="btn btn-outline-info w-100 py-3 rounded-3">

                                <i class="bi bi-people fs-4 d-block mb-2"></i>

                                کاربران

                            </a>

                        </div>

                        <div class="col-xl-2 col-lg-4 col-md-6">

                            <a asp-controller="Home"
                               asp-action="Index"
                               asp-area=""
                               target="_blank"
                               class="btn btn-outline-secondary w-100 py-3 rounded-3">

                                <i class="bi bi-globe fs-4 d-block mb-2"></i>

                                مشاهده سایت

                            </a>

                        </div>

                        <div class="col-xl-2 col-lg-4 col-md-6">

                            <form asp-controller="Account"
                                  asp-action="Logout"
                                  method="post">

                                @Html.AntiForgeryToken()

                                <button type="submit"
                                        class="btn btn-outline-danger w-100 py-3 rounded-3">

                                    <i class="bi bi-box-arrow-right fs-4 d-block mb-2"></i>

                                    خروج

                                </button>

                            </form>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>