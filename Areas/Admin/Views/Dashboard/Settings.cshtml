@{
    ViewData["Title"] = "تنظیمات";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">

    <div class="mb-4">

        <h2 class="fw-bold">
            <i class="bi bi-gear-fill text-primary ms-2"></i>
            تنظیمات فروشگاه
        </h2>

        <p class="text-muted">
            مدیریت تنظیمات کلی فروشگاه
        </p>

    </div>

    <div class="row g-4">

        <div class="col-lg-3 col-md-6">

            <a asp-area="Admin"
               asp-controller="Dashboard"
               asp-action="ShopInfo"
               class="text-decoration-none">

                <div class="card shadow border-0 h-100">

                    <div class="card-body text-center">

                        <i class="bi bi-shop fs-1 text-primary"></i>

                        <h5 class="mt-3">
                            اطلاعات فروشگاه
                        </h5>

                        <p class="text-muted mb-0">

                            نام، لوگو، توضیحات و...

                        </p>

                    </div>

                </div>

            </a>

        </div>

        <div class="col-lg-3 col-md-6">

            <a asp-action="ContactSettings"
               asp-area="Admin"
               asp-controller="Dashboard"
               class="text-decoration-none">

                <div class="card shadow border-0 h-100">

                    <div class="card-body text-center">

                        <i class="bi bi-telephone fs-1 text-success"></i>

                        <h5 class="mt-3">

                            اطلاعات تماس

                        </h5>

                        <p class="text-muted mb-0">

                            تلفن، ایمیل، آدرس

                        </p>

                    </div>

                </div>

            </a>

        </div>

        <div class="col-lg-3 col-md-6">

            <a asp-action="SocialSettings"
               asp-area="Admin"
               asp-controller="Dashboard"
               class="text-decoration-none">

                <div class="card shadow border-0 h-100">

                    <div class="card-body text-center">

                        <i class="bi bi-instagram fs-1 text-danger"></i>

                        <h5 class="mt-3">

                            شبکه‌های اجتماعی

                        </h5>

                        <p class="text-muted mb-0">

                            اینستاگرام، تلگرام و...

                        </p>

                    </div>

                </div>

            </a>

        </div>

        <div class="col-lg-3 col-md-6">

            <a asp-action="Seo"
               asp-area="Admin"
               asp-controller="Dashboard"
               class="text-decoration-none">

                <div class="card shadow border-0 h-100">

                    <div class="card-body text-center">

                        <i class="bi bi-search fs-1 text-warning"></i>

                        <h5 class="mt-3">

                            تنظیمات سئو

                        </h5>

                        <p class="text-muted mb-0">

                            Meta و Keywords

                        </p>

                    </div>

                </div>

            </a>

        </div>

        <div class="col-lg-3 col-md-6">

            <a asp-action="AboutUs"
               asp-area="Admin"
               asp-controller="Dashboard"
               class="text-decoration-none">

                <div class="card shadow border-0 h-100">

                    <div class="card-body text-center">

                        <i class="bi bi-file-earmark-text fs-1 text-info"></i>

                        <h5 class="mt-3">

                            درباره ما

                        </h5>

                        <p class="text-muted mb-0">

                            متن درباره فروشگاه

                        </p>

                    </div>

                </div>

            </a>

        </div>

        <div class="col-lg-3 col-md-6">

            <a asp-action="ShipingSettings"
               asp-area="Admin"
               asp-controller="Dashboard"
               class="text-decoration-none">

                <div class="card shadow border-0 h-100">

                    <div class="card-body text-center">

                        <i class="bi bi-truck fs-1 text-secondary"></i>

                        <h5 class="mt-3">

                            تنظیمات ارسال

                        </h5>

                        <p class="text-muted mb-0">

                            هزینه ارسال و پست

                        </p>

                    </div>

                </div>

            </a>

        </div>

        <div class="col-lg-3 col-md-6">

            <a asp-action="PaymentSettings"
               asp-area="Admin"
               asp-controller="Dashboard"
               class="text-decoration-none">

                <div class="card shadow border-0 h-100">

                    <div class="card-body text-center">

                        <i class="bi bi-credit-card fs-1 text-success"></i>

                        <h5 class="mt-3">

                            تنظیمات پرداخت

                        </h5>

                        <p class="text-muted mb-0">

                            زرین‌پال و درگاه

                        </p>

                    </div>

                </div>

            </a>

        </div>

    </div>

</div> 