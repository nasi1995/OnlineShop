@model OnlineShop.Models.Product

@{
    ViewData["Title"] = "جزئیات محصول";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold text-primary">
            <i class="bi bi-box-seam ms-2"></i>
            جزئیات محصول
        </h2>

        <div>

            <a asp-area="Admin"
               asp-controller="Dashboard"
               asp-action="EditProduct"
               asp-route-id="@Model.Id"
               class="btn btn-warning">

                <i class="bi bi-pencil-square ms-2"></i>
                ویرایش

            </a>

            <a asp-area="Admin"
               asp-controller="Dashboard"
               asp-action="Products"
               class="btn btn-secondary">

                <i class="bi bi-arrow-right ms-2"></i>
                بازگشت

            </a>

        </div>

    </div>


    <div class="card shadow border-0">

        <div class="card-body">

            <div class="row">

                <div class="col-lg-4 text-center">

                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl"
                             class="img-fluid rounded shadow"
                             style="max-height:350px;" />
                    }
                    else
                    {
                        <img src="https://placehold.co/350x350?text=No+Image"
                             class="img-fluid rounded shadow" />
                    }

                </div>

                <div class="col-lg-8">

                    <table class="table table-bordered align-middle">

                        <tbody>

                            <tr>
                                <th width="220">نام محصول</th>
                                <td>@Model.Name</td>
                            </tr>

                            <tr>
                                <th>دسته بندی</th>
                                <td>@Model.Category?.Name</td>
                            </tr>

                            <tr>
                                <th>قیمت</th>
                                <td class="text-success fw-bold">
                                    @Model.Price.ToString("N0") تومان
                                </td>
                            </tr>

                            <tr>
                                <th>قیمت قبل</th>
                                <td>
                                    @if (Model.OldPrice != null)
                                    {
                                        <span class="text-decoration-line-through text-danger">
                                            @Model.OldPrice.Value.ToString("N0") تومان
                                        </span>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                            </tr>

                            <tr>
                                <th>وزن</th>
                                <td>@Model.Weight</td>
                            </tr>

                            <tr>
                                <th>نوع محصول</th>
                                <td>@Model.ProductType</td>
                            </tr>

                            <tr>
                                <th>طعم</th>
                                <td>@Model.Flavor</td>
                            </tr>

                            <tr>
                                <th>تعداد نظرات</th>
                                <td>@Model.ReviewCount</td>
                            </tr>

                        </tbody>

                    </table>

                </div>

            </div>

            <hr />

            <h5 class="fw-bold mb-3">

                <i class="bi bi-card-text ms-2"></i>

                توضیحات محصول

            </h5>

            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <div class="border rounded p-3 bg-light">
                    @Model.Description
                </div>
            }
            else
            {
                <div class="alert alert-warning mb-0">
                    توضیحاتی برای این محصول ثبت نشده است.
                </div>
            }

        </div>

    </div>

</div>