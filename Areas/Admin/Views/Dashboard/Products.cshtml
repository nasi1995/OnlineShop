@model IEnumerable<OnlineShop.Models.Product>

@{
    ViewData["Title"] = "مدیریت محصولات";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">

    <div>

        <h2 class="fw-bold text-success">

            <i class="bi bi-box-seam ms-2"></i>

            مدیریت محصولات

        </h2>

        <span class="text-muted">

            تعداد کل محصولات :

            <strong>

                @Model.Count()

            </strong>

        </span>

    </div>

    <a asp-area="Admin"
       asp-controller="Dashboard"
       asp-action="CreateProduct"
       class="btn btn-success">

        <i class="bi bi-plus-circle ms-2"></i>

        افزودن محصول

    </a>

</div>
<div class="card border-0 shadow-sm rounded-4">

    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">

        <h5 class="fw-bold text-success mb-0">

            <i class="bi bi-box-seam ms-2"></i>

            لیست محصولات

        </h5>

        <span class="badge bg-success">

            @Model.Count() محصول

        </span>

    </div>

    <div class="table-responsive">

        <table class="table table-hover align-middle mb-0">

            <thead class="table-light">

                <tr>

                    <th width="90">تصویر</th>

                    <th>نام</th>

                    <th>دسته‌بندی</th>

                    <th>وزن</th>

                    <th>نوع</th>

                    <th>قیمت</th>

                    <th>قیمت قبلی</th>

                    <th>نظرات</th>

                    <th width="170">عملیات</th>

                </tr>

            </thead>

            <tbody>

                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>

                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl"
                                         width="60"
                                         height="60"
                                         class="rounded-3 border object-fit-cover" />
                                }
                                else
                                {
                                    <div class="bg-light rounded-3 d-flex align-items-center justify-content-center"
                                         style="width:60px;height:60px;">

                                        <i class="bi bi-image text-secondary"></i>

                                    </div>
                                }

                            </td>

                            <td>

                                <strong>

                                    @item.Name

                                </strong>

                            </td>

                            <td>

                                @(item.Category?.Name ?? "-")

                            </td>

                            <td>

                                @(item.Weight ?? "-")

                            </td>

                            <td>

                                @(item.ProductType ?? "-")

                            </td>

                            <td class="text-success fw-bold">

                                @item.Price.ToString("N0")

                            </td>

                            <td>

                                @if (item.OldPrice.HasValue)
                                {
                                    <span class="text-decoration-line-through text-danger">

                                        @item.OldPrice.Value.ToString("N0")

                                    </span>
                                }
                                else
                                {
                                    <span>-</span>
                                }

                            </td>

                            <td>

                                <span class="badge bg-warning text-dark">

                                    @item.ReviewCount

                                </span>

                            </td>

                            <td>
                                <div class="btn-group">

                                    <a asp-area=""
                                       asp-controller="Products"
                                       asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn btn-info btn-sm">

                                        <i class="bi bi-eye"></i>

                                    </a>

                                    <a asp-area="Admin"
                                       asp-controller="Dashboard"
                                       asp-action="EditProduct"
                                       asp-route-id="@item.Id"
                                       class="btn btn-outline-warning btn-sm"
                                       title="ویرایش">

                                        <i class="bi bi-pencil"></i>

                                    </a>

                                    <form asp-area="Admin"
                                          asp-controller="Dashboard"
                                          asp-action="DeleteProduct"
                                          asp-route-id="@item.Id"
                                          method="post"
                                          class="d-inline">

                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="btn btn-outline-danger btn-sm"
                                                onclick="return confirm('آیا از حذف این محصول مطمئن هستید؟')"
                                                title="حذف">

                                            <i class="bi bi-trash"></i>

                                        </button>

                                    </form>

                                </div>
                            </td>

                        </tr>
                    }
                }
                else
                {
                    <tr>

                        <td colspan="9" class="text-center py-5">

                            <i class="bi bi-inbox fs-1 text-secondary"></i>

                            <div class="mt-3">

                                محصولی یافت نشد.

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>