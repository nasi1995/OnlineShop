<!DOCTYPE html>
<html lang="fa" dir="rtl">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>@ViewData["Title"] - پنل مدیریت نبات</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@300;400;500;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>

<body>

    <!-- Overlay -->
    <div class="sidebar-overlay"></div>

    <!-- Sidebar -->
    <aside class="sidebar">

        <div class="logo">
            <h2>نبات</h2>
            <span>پنل مدیریت</span>
        </div>

        <ul class="menu">

            <li>
                <a asp-area="Admin"
                   asp-controller="Dashboard"
                   asp-action="Index">
                    <i class="bi bi-speedometer2"></i>
                    داشبورد
                </a>
            </li>

            <li>
                <a asp-area="Admin"
                   asp-controller="Dashboard"
                   asp-action="Products">
                    <i class="bi bi-box-seam"></i>
                    محصولات
                </a>
            </li>

            <li>
                <a asp-area="Admin"
                   asp-controller="Dashboard"
                   asp-action="Orders">
                    <i class="bi bi-cart3"></i>
                    سفارش‌ها
                </a>
            </li>

            <li>
                <a asp-area="Admin"
                   asp-controller="Dashboard"
                   asp-action="Users">
                    <i class="bi bi-people"></i>
                    کاربران
                </a>
            </li>

            <li>

                <div class="d-flex justify-content-between align-items-center">

                    <a asp-area="Admin"
                       asp-controller="Dashboard"
                       asp-action="Settings"
                       class="flex-grow-1">

                        <i class="bi bi-gear"></i>
                        تنظیمات

                    </a>

                    <a data-bs-toggle="collapse"
                       href="#settingsMenu">

                        <i class="bi bi-chevron-down"></i>

                    </a>

                </div>

                <div class="collapse" id="settingsMenu">

                    <ul class="list-unstyled mt-2">

                        <li>
                            <a asp-action="ShopInfo">
                                <i class="bi bi-shop"></i>
                                اطلاعات فروشگاه
                            </a>
                        </li>

                        <li>
                            <a asp-action="ContactSettings">
                                <i class="bi bi-telephone"></i>
                                اطلاعات تماس
                            </a>
                        </li>

                        <li>
                            <a asp-action="SocialSettings">
                                <i class="bi bi-instagram"></i>
                                شبکه‌های اجتماعی
                            </a>
                        </li>

                        <li>
                            <a asp-action="Seo">
                                <i class="bi bi-search"></i>
                                تنظیمات سئو
                            </a>
                        </li>

                        <li>
                            <a asp-action="AboutUs">
                                <i class="bi bi-file-earmark-text"></i>
                                درباره ما
                            </a>
                        </li>

                        <li>
                            <a asp-action="ShipingSettings">
                                <i class="bi bi-truck"></i>
                                تنظیمات ارسال
                            </a>
                        </li>

                        <li>
                            <a asp-action="PaymentSettings">
                                <i class="bi bi-credit-card"></i>
                                تنظیمات پرداخت
                            </a>
                        </li>

                    </ul>

                </div>

            </li>

        </ul>

    </aside>

    <!-- Content -->
    <main class="content">

        <header class="topbar">

            <div class="topbar-left">

                <button class="menu-toggle d-lg-none">
                    <i class="bi bi-list"></i>
                </button>

                <h4>@ViewData["Title"]</h4>

            </div>

            <div class="user-info">

                <i class="bi bi-person-circle fs-3 text-success"></i>

                <div>
                    <h6 class="mb-0">مدیر سیستم</h6>
                    <small>خوش آمدید</small>
                </div>

            </div>

        </header>

        @RenderBody()

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>

    <script>

        const sidebar = document.querySelector(".sidebar");
        const overlay = document.querySelector(".sidebar-overlay");
        const menuBtn = document.querySelector(".menu-toggle");

        menuBtn.addEventListener("click", () => {
        sidebar.classList.toggle("show");
        overlay.classList.toggle("show");
        });

        overlay.addEventListener("click", () => {
        sidebar.classList.remove("show");
        overlay.classList.remove("show");
        });

    </script>

    @RenderSection("Scripts", required: false)

</body>

</html>