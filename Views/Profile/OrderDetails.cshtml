@model OnlineShop.Models.Order

@{
    ViewData["Title"] = "جزئیات سفارش";
}

<div class="container py-5">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-header bg-success text-white py-3">

            <h3 class="mb-0">
                جزئیات سفارش #@Model.Id
            </h3>

        </div>


        <div class="card-body">

            <div class="row mb-4">

                <div class="col-md-6">

                    <p>
                        <strong>نام گیرنده :</strong>
                        @Model.FullName
                    </p>

                    <p>
                        <strong>شماره موبایل :</strong>
                        @Model.Mobile
                    </p>

                    <p>
                        <strong>استان :</strong>
                        @Model.Province
                    </p>

                    <p>
                        <strong>شهر :</strong>
                        @Model.City
                    </p>

                </div>


                <div class="col-md-6">

                    <p>
                        <strong>روش ارسال :</strong>
                        @Model.ShippingMethod
                    </p>

                    <p>
                        <strong>روش پرداخت :</strong>
                        @Model.PaymentMethod
                    </p>

                    <p>
                        <strong>تاریخ سفارش :</strong>
                        @Model.CreatedAt.ToString("yyyy/MM/dd HH:mm")
                    </p>

                    <p>

                        <strong>وضعیت پرداخت :</strong>

                        @switch (Model.PaymentStatus)
                        {
                            case "Paid":
                                <span class="badge bg-success">
                                    پرداخت شده
                                </span>
                                break;

                            case "Pending":
                                <span class="badge bg-warning text-dark">
                                    در انتظار پرداخت
                                </span>
                                break;

                            case "Failed":
                                <span class="badge bg-danger">
                                    ناموفق
                                </span>
                                break;

                            default:
                                <span class="badge bg-secondary">
                                    @Model.PaymentStatus
                                </span>
                                break;
                        }

                    </p>

                </div>

            </div>



            <div class="mb-4">

                <h4 class="mb-3">
                    آدرس ارسال
                </h4>

                <div class="alert alert-light border">

                    @Model.Address

                </div>

            </div>




            <h4 class="mb-3">
                محصولات سفارش
            </h4>

            <table class="table table-bordered align-middle text-center">

                <thead class="table-success">

                    <tr>

                        <th>محصول</th>

                        <th>تعداد</th>

                        <th>قیمت</th>

                        <th>جمع</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model.Items)
                    {
                        <tr>

                            <td>
                                @item.ProductName
                            </td>

                            <td>
                                @item.Quantity
                            </td>

                            <td>
                                @item.Price.ToString("N0")
                                تومان
                            </td>

                            <td>
                                @((item.Price * item.Quantity).ToString("N0"))
                                تومان
                            </td>

                        </tr>
                    }

                </tbody>

            </table>



            <div class="text-end mt-4">

                <h4>

                    مبلغ کل :

                    <span class="text-success">

                        @Model.TotalPrice.ToString("N0")

                        تومان

                    </span>

                </h4>

            </div>



            <div class="mt-5 text-center">

                <a asp-action="Dashboard"
                   class="btn btn-outline-success">

                    بازگشت به سفارش‌ها

                </a>

            </div>

        </div>

    </div>

</div>