@using Microsoft.AspNetCore.Identity
@using OnlineShop.Models
@using Newtonsoft.Json
@using OnlineShop.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    var currentUser = await UserManager.GetUserAsync(User);
}
@{
    var cartCount = 0;

    var cartSession = Context.Session.GetString("Cart");

    if (!string.IsNullOrEmpty(cartSession))
    {
        var cartItems = JsonConvert.DeserializeObject<List<CartItem>>(cartSession);

        if (cartItems != null)
        {
            cartCount = cartItems.Sum(x => x.Quantity);
        }
    }
}

<header class="main-header">
    <nav class="navbar navbar-expand-lg navbar-dark custom-navbar">
        <div class="container-fluid px-lg-5">

            <div class="mobile-header d-flex d-lg-none align-items-center justify-content-between w-100">

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainMenu">
                    <i class="bi bi-list"></i>
                </button>

                <a class="logo" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.png" alt="نبات">
                </a>

                <div class="mobile-icons">

                    @if (SignInManager.IsSignedIn(User))
                    {
                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="login-icon border-0">
                                <i class="bi bi-box-arrow-right"></i>
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="login-icon">
                            <i class="bi bi-person"></i>
                        </a>
                    }

                    <a asp-controller="Cart"
                       asp-action="Index"
                       class="cart-icon">

                        <i class="bi bi-bag"></i>

                        <span>
                            @cartCount
                        </span>

                    </a>

                </div>

            </div>

            <a class="navbar-brand logo d-none d-lg-block" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo.png" alt="نبات">
            </a>

            <div class="collapse navbar-collapse" id="mainMenu">

                <ul class="navbar-nav mx-auto">

                    <li class="nav-item">
                        <a class="nav-link active" asp-controller="Home" asp-action="Index">خانه</a>
                    </li>

                    <li class="nav-item dropdown">

                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            محصولات
                        </a>

                        <ul class="dropdown-menu custom-dropdown" dir="rtl">

                            <li><a class="dropdown-item" asp-controller="Products" asp-action="Index">نبات زعفرانی</a></li>
                            <li><a class="dropdown-item" asp-controller="Products" asp-action="Index">نبات چوبی</a></li>
                            <li><a class="dropdown-item" asp-controller="Products" asp-action="Index">نبات طعم‌دار</a></li>
                            <li><a class="dropdown-item" asp-controller="Products" asp-action="Index">پک هدیه</a></li>

                        </ul>

                    </li>

                    <li class="nav-item">
<a class="nav-link" asp-controller="Home" asp-action="About">درباره ما</a>
</li>
<li class="nav-item">
<a class="nav-link" asp-controller="Home" asp-action="Contact">تماس با ما</a>
</li>

</ul>

<form class="search-box d-none d-lg-flex">
<input type="text" placeholder="جستجوی محصولات">
<button type="submit">
<i class="bi bi-search"></i>
</button>
</form>

<div class="header-icons d-none d-lg-flex">

@if(SignInManager.IsSignedIn(User))
{
<div class="dropdown">

<a href="#" class="login-btn dropdown-toggle" data-bs-toggle="dropdown">
<i class="bi bi-person-circle"></i>
   خوش آمدی, @currentUser?.FullName
</a>

                            <ul class="dropdown-menu dropdown-menu-end">

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Profile"
                                       asp-action="Dashboard">

                                        <i class="bi bi-person-circle me-2"></i>

                                        حساب کاربری

                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Profile"
                                       asp-action="Dashboard">

                                        <i class="bi bi-bag me-2"></i>

                                        سفارش‌های من

                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Profile"
                                       asp-action="Dashboard">

                                        <i class="bi bi-gear me-2"></i>

                                        تنظیمات حساب

                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-controller="Profile"
                                       asp-action="Orders">

                                        <i class="bi bi-bag me-2"></i>
                                        سفارش‌های من

                                    </a>
                                </li>
                                <li>
                                    <hr class="dropdown-divider">
                                </li>

                                <li>
                                    <form asp-controller="Account"
                                          asp-action="Logout"
                                          method="post">

                                        @Html.AntiForgeryToken()

                                        <button type="submit"
                                                class="dropdown-item">

                                            <i class="bi bi-box-arrow-right me-2"></i>

                                            خروج

                                        </button>

                                    </form>
                                </li>

                            </ul>

</div>
}
else
{
<a asp-controller="Account" asp-action="Login" class="login-btn">
<i class="bi bi-box-arrow-in-right"></i>
ورود
</a>
}

<a href="#">
<i class="bi bi-heart"></i>
</a>

                    <a asp-controller="Cart"
                       asp-action="Index"
                       class="cart-mobile">

                        <i class="bi bi-bag"></i>

                        <span>
                            @cartCount
                        </span>

                    </a>

</div>

</div>

</div>

</nav>

</header>