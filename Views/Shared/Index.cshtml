@model List<OnlineShop.Models.CartItem>

@{
    ViewData["Title"] = "سبد خرید";
    decimal total = Model?.Sum(x => x.Total) ?? 0;
    }

<section class="cart-section py-5">

    <div class="container">

        <h2 class="mb-4 text-center">
            سبد خرید شما
        </h2>

        @if (Model == null || !Model.Any())
        {
            <div class="alert alert-warning text-center rounded-4">

                سبد خرید شما خالی است.

                <br />

                <a asp-controller="Products"
                   asp-action="Index"
                   class="btn btn-success mt-3 rounded-pill">

                    مشاهده محصولات

                </a>

            </div>
        }
        else
        {

            <div class="table-responsive">

                <table class="table align-middle text-center">

                    <thead>

                        <tr>

                            <th>محصول</th>

                            <th>قیمت</th>

                            <th>تعداد</th>

                            <th>مجموع</th>

                            <th></th>

                        </tr>

                    </thead>


                    <tbody>


                        @foreach (var item in Model)
                        {

                            <tr>

                                <td>

                                    <div class="d-flex align-items-center gap-3">


                                        <img src="@item.ImageUrl"
                                             width="70"
                                             height="70"
                                             class="rounded-3"
                                             style="object-fit:cover">


                                        <span>
                                            @item.Name
                                        </span>


                                    </div>


                                </td>



                                <td>

                                    @item.Price.ToString("N0")
                                    تومان

                                </td>



                                <td>

                                    @item.Quantity

                                </td>



                                <td>

                                    @item.Total.ToString("N0")
                                    تومان

                                </td>



                                <td>

                                    <a asp-controller="Cart"
                                       asp-action="Remove"
                                       asp-route-id="@item.ProductId"
                                       class="btn btn-danger btn-sm rounded-pill">

                                        حذف

                                    </a>

                                </td>


                            </tr>

                        }


                    </tbody>


                </table>


            </div>



            <div class="cart-summary mt-4 p-4 rounded-4 shadow-sm">


                <h4>

                    مبلغ نهایی:

                    <span class="text-success">

                        @total.ToString("N0")
                        تومان

                    </span>

                </h4>

                <div class="cart-actions d-flex justify-content-between align-items-center mt-5 flex-wrap gap-3">

                    <a asp-controller="Products"
                       asp-action="Index"
                       class="nabat-btn nabat-outline">

                        <i class="bi bi-arrow-right"></i>

                        ادامه خرید

                    </a>
                    <a asp-controller="Payment"
                       asp-action="Index"
                       class="nabat-btn">

                        <i class="bi bi-credit-card"></i>

                        ادامه پرداخت

                    </a>


                </div>



            </div>

        }

    </div>

</section>